---
/**
 * SignupForm — email signup for voter guide notifications.
 *
 * Posts JSON { email, zip, source } to SIGNUP_ENDPOINT from site.ts.
 * When endpoint is empty (stub), logs to console and shows success state
 * so the component is testable before a backend is chosen.
 */
import { SIGNUP_ENABLED, SIGNUP_ENDPOINT } from '../data/site';
---

{SIGNUP_ENABLED && <div class="signup-form-wrap">
  <form class="signup-form" data-endpoint={SIGNUP_ENDPOINT} novalidate>
    <div class="signup-fields">
      <div class="signup-field">
        <label for="signup-email">Email</label>
        <input
          type="email"
          id="signup-email"
          name="email"
          required
          autocomplete="email"
          placeholder="you@example.com"
        />
      </div>
      <div class="signup-field signup-field-zip">
        <label for="signup-zip">Zip <span class="signup-optional">(optional)</span></label>
        <input
          type="text"
          id="signup-zip"
          name="zip"
          pattern="[0-9]{5}"
          inputmode="numeric"
          maxlength="5"
          placeholder="90501"
          autocomplete="postal-code"
        />
      </div>
      <button type="submit" class="dl-btn signup-btn">Notify me</button>
    </div>
    <div class="signup-status" aria-live="polite"></div>
  </form>
</div>

<script is:inline>
(function () {
  document.querySelectorAll('.signup-form').forEach(function (form) {
    if (form.dataset.bound) return;
    form.dataset.bound = 'true';

    form.addEventListener('submit', function (e) {
      e.preventDefault();
      var emailInput = form.querySelector('input[name="email"]');
      var zipInput = form.querySelector('input[name="zip"]');
      var statusEl = form.querySelector('.signup-status');
      var email = emailInput.value.trim();
      var zip = zipInput.value.trim();

      // Browser validation
      if (!email || !emailInput.checkValidity()) {
        emailInput.reportValidity();
        return;
      }
      if (zip && !zipInput.checkValidity()) {
        zipInput.reportValidity();
        return;
      }

      var endpoint = form.dataset.endpoint;
      var payload = { email: email, zip: zip || null, source: 'torrancewatch.org' };

      // Stub behavior: no endpoint configured yet, log and show success
      if (!endpoint) {
        console.log('[SignupForm] No endpoint configured. Payload:', payload);
        showSuccess(form, statusEl);
        return;
      }

      // POST to configured endpoint
      var btn = form.querySelector('button[type="submit"]');
      btn.disabled = true;
      btn.textContent = 'Sending...';

      fetch(endpoint, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      })
        .then(function (res) {
          if (!res.ok) throw new Error('HTTP ' + res.status);
          showSuccess(form, statusEl);
        })
        .catch(function () {
          btn.disabled = false;
          btn.textContent = 'Notify me';
          statusEl.className = 'signup-status signup-error';
          statusEl.innerHTML = 'Something went wrong. Please try again or email <a href="mailto:hello@torrancewatch.org">hello@torrancewatch.org</a>.';
        });
    });

    function showSuccess(form, statusEl) {
      form.querySelector('.signup-fields').style.display = 'none';
      statusEl.className = 'signup-status signup-success';
      statusEl.textContent = "Thanks. We'll email you when we publish something new.";
    }
  });
})();
</script>}

<style>
  .signup-form-wrap {
    margin-top: 1rem;
  }
  .signup-fields {
    display: flex;
    gap: 8px;
    align-items: flex-end;
    flex-wrap: wrap;
  }
  .signup-field {
    flex: 1 1 200px;
  }
  .signup-field-zip {
    flex: 0 0 100px;
  }
  .signup-field label {
    display: block;
    font-size: 12px;
    color: #888;
    margin-bottom: 4px;
    font-weight: 500;
  }
  .signup-optional {
    font-weight: 400;
    color: #aaa;
  }
  .signup-field input {
    width: 100%;
    height: 44px;
    padding: 0 12px;
    font-size: 14px;
    font-family: 'Source Sans 3', sans-serif;
    color: #1a1a1a;
    background: #fff;
    border: 1px solid #ddd;
    border-radius: 8px;
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .signup-field input:focus {
    border-color: #C0392B;
    box-shadow: 0 0 0 3px rgba(192, 57, 43, 0.1);
  }
  .signup-field input::placeholder {
    color: #bbb;
  }
  .signup-btn {
    height: 44px;
    flex-shrink: 0;
    margin-bottom: 0;
  }
  .signup-status {
    margin-top: 0.75rem;
    font-size: 13px;
    line-height: 1.5;
  }
  .signup-success {
    color: #0F6E56;
  }
  .signup-error {
    color: #B83230;
  }
  .signup-error a {
    color: #B83230;
    text-decoration: underline;
  }
  @media (max-width: 540px) {
    .signup-fields {
      flex-direction: column;
    }
    .signup-field-zip {
      flex: 1 1 auto;
    }
    .signup-btn {
      width: 100%;
    }
  }
</style>
