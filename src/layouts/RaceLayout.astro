---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description?: string;
  kicker?: string;
  headline: string;
  dek?: string;
  source?: string;
}

const { title, description, kicker, headline, dek, source } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <div class="page">
    {kicker && <div class="kicker">{kicker}</div>}
    <h1>{headline}</h1>
    {dek && <div class="dek">{dek}</div>}
    {source && <div class="source" set:html={source} />}
    <slot />
  </div>
</BaseLayout>
