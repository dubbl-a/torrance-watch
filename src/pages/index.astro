---
import BaseLayout from '../layouts/BaseLayout.astro';
import SignupForm from '../components/SignupForm.astro';
import { description, SIGNUP_ENABLED } from '../data/site';
---

<BaseLayout
  title="Home"
  description={description}
  ogTitle="Torrance Watch | Nonpartisan civic reference for the City of Torrance"
  ogDescription={description}
>
  <div class="page">
    <div class="kicker">Torrance 2026 elections</div>
    <h1>See who's funding your June 2 ballot.</h1>
    <div class="dek">
      Campaign finance for Torrance's mayor, council, and treasurer races, sourced from public filings.
    </div>

    <div class="section">
      <div class="section-head">Campaign finance tracker</div>
      <div class="section-sub">
        Campaign finance data from public filings, broken down by donor
        geography, occupation, and contribution size.
      </div>
      <div class="stat-row" style="grid-template-columns:1fr;">
        <a href="/finance/2026/mayor-2026" class="stat" style="text-decoration:none;">
          <div class="stat-label">Mayor</div>
          <div class="stat-note" style="color:#555;margin-top:2px;">George Chen vs. Sharon Kalani</div>
          <div class="stat-note" style="margin-top:6px;">View finance data &rarr;</div>
        </a>
      </div>
      <div class="stat-row">
        <a href="/finance/2026/district-1-2026" class="stat" style="text-decoration:none;">
          <div class="stat-label">District 1 Council</div>
          <div class="stat-note" style="color:#555;margin-top:2px;">Jon Kaji vs. David Kartsonis</div>
          <div class="stat-note" style="margin-top:6px;">View finance data &rarr;</div>
        </a>
        <a href="/finance/2026/treasurer-2026" class="stat" style="text-decoration:none;">
          <div class="stat-label">City Treasurer</div>
          <div class="stat-note" style="color:#555;margin-top:2px;">Aurelio Mattucci vs. Mike Griffiths</div>
          <div class="stat-note stat-note-sub" style="margin-top:4px;">Finance data currently available for Mattucci only.</div>
          <div class="stat-note" style="margin-top:6px;">View finance data &rarr;</div>
        </a>
      </div>
    </div>

    {SIGNUP_ENABLED && (
      <div class="section">
        <div class="section-head">Stay informed</div>
        <div class="section-sub">
          Get an email when we publish something new.
        </div>
        <SignupForm />
        <p style="font-size:12px;color:#999;margin-top:0.75rem;line-height:1.5;">
          We don't share your email. We don't send anything else. Unsubscribe any time.
        </p>
      </div>
    )}
  </div>
</BaseLayout>

<style>
  .page > .dek { margin-bottom: 2.5rem; }
  .stat-note-sub { color: #888; font-style: italic; }
</style>
